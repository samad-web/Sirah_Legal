# ── Frontend env vars (exposed to the browser via Vite) ──────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Server-only env vars (never exposed to the browser) ──────────────────────
# Same URL as VITE_SUPABASE_URL — used by the Express server
SUPABASE_URL=https://your-project-ref.supabase.co
# Same key as VITE_SUPABASE_ANON_KEY — used by Express for JWT verification fallback
SUPABASE_ANON_KEY=your-anon-key-here
# Get this from Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Get this from Supabase dashboard → Settings → API → JWT Settings → JWT Secret
# Required for local JWT verification (avoids per-request network calls to Supabase)
SUPABASE_JWT_SECRET=your-jwt-secret-here
# OpenAI API key — used by the Express server to call the AI API
OPENAI_API_KEY=sk-...
# Express server port (default: 3001)
PORT=3001
# Allowed frontend origin in production (e.g. https://yourdomain.com)
# Leave unset if the frontend is served from the same Express process
FRONTEND_ORIGIN=
